{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VisualRenderManifest",
  "type": "object",
  "required": ["project_id", "global_style", "scene_manifests"],
  "properties": {
    "project_id": { "type": "string" },
    "global_style": {
      "type": "object",
      "required": ["color_palette", "caption_style", "background_texture"],
      "properties": {
        "color_palette": { "type": "string" },
        "caption_style": { "type": "string" },
        "background_texture": { "type": "string" }
      }
    },
    "scene_manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_ref_id", "template_component", "visual_source", "transition_in", "foley_trigger"],
        "properties": {
          "scene_ref_id": { "type": "string" },
          "template_component": { "type": "string", "enum": ["headline_zoom", "split_screen_broll", "polaroid_pan", "column_drift"] },
          "visual_source": {
            "type": "object",
            "required": ["source_type"],
            "properties": {
              "source_type": { "type": "string", "enum": ["magazine_scan", "external_broll"] },
              "target_page_number": { "type": "integer" },
              "crop_bbox_pct": { "type": "array", "items": { "type": "number", "minimum": 0.0, "maximum": 100.0 }, "minItems": 4, "maxItems": 4 },
              "broll_search_query": { "type": "string" }
            }
          },
          "transition_in": { "type": "string" },
          "foley_trigger": { "type": "string", "enum": ["none", "paper_swoosh", "camera_shutter", "vinyl_crackle", "impact_hit"] }
        }
      }
    }
  }
}