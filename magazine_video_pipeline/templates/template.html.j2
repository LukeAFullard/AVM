<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:wght@700&family=Oswald:wght@700&display=swap" rel="stylesheet">
  <style>
    :root {
      --xmin: {{ bbox[0] }};
      --ymin: {{ bbox[1] }};
      --xmax: {{ bbox[2] }};
      --ymax: {{ bbox[3] }};
      --primary-color: {{ global_style.primary_color | default('#FFD700') }};
      --secondary-color: {{ global_style.secondary_color | default('#FF0055') }};
      --font-family: '{{ global_style.font_family | default("Bebas Neue") }}', 'Impact', 'Arial Black', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { width: 1080px; height: 1920px; overflow: hidden; background-color: #1a1a1a; font-family: var(--font-family); }
    #viewport { width: 1080px; height: 1920px; position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center; }

    .magazine-container { width: 900px; height: 1300px; position: absolute; top: 150px; overflow: hidden; border-radius: 12px; box-shadow: 0px 20px 50px rgba(0,0,0,0.8); border: 2px solid #333; transition: none; }
    #magazine-image { width: 100%; height: 100%; object-fit: contain; transform-origin: top left; transform: scale(1) translate(0%, 0%); transition: none; }

    #captions-layer { position: absolute; bottom: 220px; width: 900px; text-align: center; z-index: 10; line-height: 1.2; }
    .word { display: inline-block; font-size: 72px; color: #FFFFFF; text-transform: uppercase; margin: 0 6px; text-shadow: 3px 3px 0px #000, -3px -3px 0px #000, 3px -3px 0px #000, -3px 3px 0px #000, 0px 8px 20px rgba(0,0,0,0.9); opacity: 0.4; transform: scale(0.95); transition: none; }
    .word.active { color: var(--primary-color); opacity: 1.0; text-decoration: underline; text-decoration-color: var(--secondary-color); text-decoration-thickness: 6px; }
    .word.past { opacity: 0.9; transform: scale(1.0); }

    #progress-bar { position: absolute; bottom: 0; left: 0; height: 8px; background: var(--primary-color); width: 0%; z-index: 20; }
    #vignette { position: absolute; inset: 0; background: radial-gradient(circle, transparent 50%, rgba(0,0,0,0.8) 150%); pointer-events: none; z-index: 30; }
    #film-grain { position: absolute; inset: 0; background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E'); opacity: 0.15; pointer-events: none; z-index: 90; }
    #fade-overlay { position: absolute; inset: 0; background: black; pointer-events: none; z-index: 100; opacity: 1; }

    /* Branding & CTA */
    #branding-watermark { position: absolute; top: 40px; right: 40px; font-size: 32px; color: rgba(255, 255, 255, 0.5); z-index: 80; font-family: monospace; letter-spacing: 2px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); }
    #cta-container { position: absolute; top: 40px; left: 40px; background: #FF0000; color: white; padding: 12px 24px; border-radius: 50px; font-size: 36px; font-weight: bold; z-index: 80; box-shadow: 0px 8px 20px rgba(0,0,0,0.6); transform: scale(0); opacity: 0; transform-origin: left center; }
  </style>
</head>
<body>
  <div id="viewport">
    <div id="branding-watermark">@VintageStories</div>
    <div id="cta-container">SUBSCRIBE</div>
    <div id="vignette"></div>
    <div id="film-grain"></div>
    <div id="fade-overlay"></div>
    <div id="progress-bar"></div>
    <div class="magazine-container" id="mag-container">
      <img id="magazine-image" src="{{ image_path }}" alt="Magazine Scan">
    </div>
    <div id="captions-layer">
      {% for item in timestamps %}
        <span class="word" data-start="{{ item.start }}" data-end="{{ item.end }}">{{ item.word }}</span>
      {% endfor %}
    </div>
  </div>
  <script>
    // Remotion-style Animation Utilities
    const random = (seed) => {
        let t = seed += 0x6D2B79F5;
        t = Math.imul(t ^ t >>> 15, t | 1);
        t ^= t + Math.imul(t ^ t >>> 7, t | 61);
        return ((t ^ t >>> 14) >>> 0) / 4294967296;
    };

    const clamp = (val, min, max) => Math.min(Math.max(val, min), max);

    // Easing functions
    const Easing = {
        linear: (t) => t,
        quad: (t) => t * t,
        cubic: (t) => t * t * t,
        out: (easing) => (t) => 1 - easing(1 - t),
        inOut: (easing) => (t) => {
            if (t < 0.5) {
                return easing(t * 2) / 2;
            }
            return 1 - easing((1 - t) * 2) / 2;
        }
    };

    const interpolate = (value, inputRange, outputRange, options = {}) => {
        const { easing = Easing.linear, extrapolateLeft = 'clamp', extrapolateRight = 'clamp' } = options;
        const [inMin, inMax] = inputRange;
        const [outMin, outMax] = outputRange;

        // Easing interpolation requires normalizing input between 0 and 1
        let progress = (value - inMin) / (inMax - inMin);

        // Extrapolate logic
        if (progress < 0) {
            if (extrapolateLeft === 'clamp') progress = 0;
        } else if (progress > 1) {
            if (extrapolateRight === 'clamp') progress = 1;
        }

        const easedProgress = easing(progress);

        // Linearly map the eased progress back to output range
        return outMin + (easedProgress * (outMax - outMin));
    };

    // Remotion-style Sequence Utility
    const Sequence = ({ frame, from, durationInFrames }) => {
        const localFrame = frame - from;
        const isActive = localFrame >= 0 && localFrame < durationInFrames;
        const clampedLocalFrame = clamp(localFrame, 0, durationInFrames - 1);
        const isPast = localFrame >= durationInFrames;
        return { isActive, localFrame: clampedLocalFrame, isPast, rawLocalFrame: localFrame };
    };

    // Remotion-style Spring Utility
    const spring = ({ frame, fps, config }) => {
        const { damping, mass, stiffness } = config;
        const t = frame / fps;

        // Critical damping calc: c = 2 * sqrt(mass * stiffness)
        const dampingRatio = damping / (2 * Math.sqrt(mass * stiffness));
        const w0 = Math.sqrt(stiffness / mass);

        if (t < 0) return 0;

        // Underdamped spring equation
        if (dampingRatio < 1) {
            const wd = w0 * Math.sqrt(1 - dampingRatio * dampingRatio);
            const A = 1;
            const B = (dampingRatio * w0) / wd;
            return 1 - Math.exp(-dampingRatio * w0 * t) * (A * Math.cos(wd * t) + B * Math.sin(wd * t));
        } else {
            // Critically damped (simplified)
            return 1 - Math.exp(-w0 * t) * (1 + w0 * t);
        }
    };

    // Initialize coordinate math for Ken Burns zoom
    const words = Array.from(document.querySelectorAll('.word')).map(el => ({
      element: el, start: parseFloat(el.dataset.start), end: parseFloat(el.dataset.end)
    }));
    const magImage = document.getElementById('magazine-image');
    const magContainer = document.getElementById('mag-container');
    const progressBar = document.getElementById('progress-bar');
    const fadeOverlay = document.getElementById('fade-overlay');
    const filmGrain = document.getElementById('film-grain');
    const ctaContainer = document.getElementById('cta-container');

    const xmin = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--xmin'));
    const ymin = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--ymin'));
    const xmax = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--xmax'));
    const ymax = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--ymax'));

    const targetScale = 100 / (xmax - xmin);
    const targetTranslateX = -1 * xmin;
    const targetTranslateY = -1 * ymin;

    // Called deterministically by Python Playwright per frame
    window.seekToFrame = function(frame, fps) {
      const totalFrames = {{ duration_sec }} * fps;
      const currentTime = frame / fps;
      const progress = clamp(frame / totalFrames, 0, 1);

      // Get parameterized easing
      const easingType = '{{ global_style.animation_easing | default("cubic") }}';
      let easingFunc = Easing.out(Easing.cubic);
      if (easingType === 'linear') easingFunc = Easing.linear;
      else if (easingType === 'quad') easingFunc = Easing.out(Easing.quad);
      else if (easingType === 'spring') easingFunc = (t) => spring({ frame: t * totalFrames, fps: fps, config: { damping: 10, mass: 1, stiffness: 100 }});

      // Remotion-style interpolations
      const currentScale = interpolate(progress, [0, 1], [1, targetScale], { easing: easingFunc });
      let currentTx = interpolate(progress, [0, 1], [0, targetTranslateX], { easing: easingFunc });
      let currentTy = interpolate(progress, [0, 1], [0, targetTranslateY], { easing: easingFunc });

      // Film grain flickering (math shift)
      filmGrain.style.backgroundPosition = `${random(frame) * 100}px ${random(frame + 1000) * 100}px`;

      // Fade In / Out using interpolate
      if (progress < 0.05) {
          fadeOverlay.style.opacity = interpolate(progress, [0, 0.05], [1, 0], { easing: Easing.linear });
      } else if (progress > 0.95) {
          fadeOverlay.style.opacity = interpolate(progress, [0.95, 1], [0, 1], { easing: Easing.linear });
      } else {
          fadeOverlay.style.opacity = 0;
      }

      // Progress bar using interpolate
      progressBar.style.width = `${interpolate(progress, [0, 1], [0, 100], { easing: Easing.linear })}%`;

      // CTA Pop Animation (appears at 85% progress)
      if (progress > 0.85) {
          const ctaProgress = (progress - 0.85) / 0.15; // Normalize to 0-1 over the last 15%
          // Map to local frames for spring function
          const ctaLocalFrame = ctaProgress * totalFrames * 0.15;
          const ctaSpring = spring({
              frame: ctaLocalFrame,
              fps: fps,
              config: { damping: 12, mass: 1, stiffness: 120 }
          });
          ctaContainer.style.transform = `scale(${ctaSpring})`;
          ctaContainer.style.opacity = interpolate(ctaProgress, [0, 0.2], [0, 1], { easing: Easing.linear });
      } else {
          ctaContainer.style.transform = `scale(0)`;
          ctaContainer.style.opacity = 0;
      }

      for (let i = 0; i < words.length; i++) {
        const w = words[i];
        w.element.classList.remove('active', 'past');

        const wordStartFrame = w.start * fps;
        const wordDurationFrames = (w.end - w.start) * fps;

        const { isActive, localFrame, isPast } = Sequence({
            frame: frame,
            from: wordStartFrame,
            durationInFrames: wordDurationFrames
        });

        if (isActive) {
            w.element.classList.add('active');

            // Calculate pop/bounce math based on localFrame using Remotion-style spring
            const springProgress = spring({
                frame: localFrame,
                fps: fps,
                config: { damping: 10, mass: 1, stiffness: 100 }
            });
            // Map spring progress [0, 1] to scale [0.95, 1.15]
            const popScale = interpolate(springProgress, [0, 1], [0.95, 1.15], { easing: Easing.linear });
            w.element.style.transform = `scale(${popScale})`;
        } else if (isPast) {
            w.element.classList.add('past');
            w.element.style.transform = `scale(1.0)`;
        } else {
            w.element.style.transform = `scale(0.95)`;
        }
      }

      // Dynamic Panning: Smooth continuous pan over the scene duration
      // Mathematically derive a pan direction tracking word progression (like reading)
      let targetPanTx = -10;
      let targetPanTy = -5;

      // Calculate a pan target based on the currently active or last active word
      let wordProgress = progress;
      if (words.length > 0) {
          // Find currently active word
          let activeIndex = words.findIndex(w => (frame / fps) >= w.start && (frame / fps) <= w.end);
          if (activeIndex === -1) {
              // Find the last word that was active
              activeIndex = words.findLastIndex(w => (frame / fps) > w.end);
              if (activeIndex === -1) activeIndex = 0; // fallback before first word
          }

          wordProgress = activeIndex / Math.max(1, words.length - 1);
      }

      // Smooth out word progress to pan target using interpolate (pan left as words progress)
      // Base pan + progressive pan
      const basePanTx = interpolate(progress, [0, 1], [0, -5], { easing: Easing.linear });
      const basePanTy = interpolate(progress, [0, 1], [0, -3], { easing: Easing.linear });

      const dynamicPanTx = interpolate(wordProgress, [0, 1], [0, -8], { easing: Easing.out(Easing.quad) });
      const dynamicPanTy = interpolate(wordProgress, [0, 1], [0, -4], { easing: Easing.out(Easing.quad) });

      magImage.style.transform = `scale(${currentScale}) translate(${currentTx + basePanTx + dynamicPanTx}%, ${currentTy + basePanTy + dynamicPanTy}%)`;

      // Dynamic Shadow using interpolate
      const shadowBlur = interpolate(currentScale, [1, targetScale], [50, 50 + (targetScale * 20)], { easing: Easing.linear });
      magContainer.style.boxShadow = `0px 20px ${shadowBlur}px rgba(0,0,0,0.8)`;
    };
  </script>
</body>
</html>