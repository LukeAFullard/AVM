<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    :root {
      --xmin: {{ bbox[0] }};
      --ymin: {{ bbox[1] }};
      --xmax: {{ bbox[2] }};
      --ymax: {{ bbox[3] }};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { width: 1080px; height: 1920px; overflow: hidden; background-color: #1a1a1a; font-family: 'Impact', 'Arial Black', sans-serif; }
    #viewport { width: 1080px; height: 1920px; position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center; }

    .magazine-container { width: 900px; height: 1300px; position: absolute; top: 150px; overflow: hidden; border-radius: 12px; box-shadow: 0px 20px 50px rgba(0,0,0,0.8); border: 2px solid #333; transition: none; }
    #magazine-image { width: 100%; height: 100%; object-fit: contain; transform-origin: top left; transform: scale(1) translate(0%, 0%); transition: none; }

    #captions-layer { position: absolute; bottom: 220px; width: 900px; text-align: center; z-index: 10; line-height: 1.2; }
    .word { display: inline-block; font-size: 72px; color: #FFFFFF; text-transform: uppercase; margin: 0 6px; text-shadow: 3px 3px 0px #000, -3px -3px 0px #000, 3px -3px 0px #000, -3px 3px 0px #000, 0px 8px 20px rgba(0,0,0,0.9); opacity: 0.4; transform: scale(0.95); transition: none; }
    .word.active { color: #FFD700; opacity: 1.0; text-decoration: underline; text-decoration-color: #FF0055; text-decoration-thickness: 6px; }
    .word.past { opacity: 0.9; transform: scale(1.0); }

    #progress-bar { position: absolute; bottom: 0; left: 0; height: 8px; background: #FFD700; width: 0%; z-index: 20; }
    #vignette { position: absolute; inset: 0; background: radial-gradient(circle, transparent 50%, rgba(0,0,0,0.8) 150%); pointer-events: none; z-index: 30; }
    #fade-overlay { position: absolute; inset: 0; background: black; pointer-events: none; z-index: 100; opacity: 1; }
  </style>
</head>
<body>
  <div id="viewport">
    <div id="vignette"></div>
    <div id="fade-overlay"></div>
    <div id="progress-bar"></div>
    <div class="magazine-container" id="mag-container">
      <img id="magazine-image" src="file://{{ image_path }}" alt="Magazine Scan">
    </div>
    <div id="captions-layer">
      {% for item in timestamps %}
        <span class="word" data-start="{{ item.start }}" data-end="{{ item.end }}">{{ item.word }}</span>
      {% endfor %}
    </div>
  </div>
  <script>
    // Initialize coordinate math for Ken Burns zoom
    const words = Array.from(document.querySelectorAll('.word')).map(el => ({
      element: el, start: parseFloat(el.dataset.start), end: parseFloat(el.dataset.end)
    }));
    const magImage = document.getElementById('magazine-image');
    const magContainer = document.getElementById('mag-container');
    const progressBar = document.getElementById('progress-bar');
    const fadeOverlay = document.getElementById('fade-overlay');

    const xmin = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--xmin'));
    const ymin = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--ymin'));
    const xmax = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--xmax'));
    const ymax = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--ymax'));

    const targetScale = 100 / (xmax - xmin);
    const targetTranslateX = -1 * xmin;
    const targetTranslateY = -1 * ymin;

    // Called deterministically by Python Playwright per frame
    window.seekToFrame = function(frame, fps, totalFrames) {
      const currentTime = frame / fps;
      const progress = Math.min(frame / totalFrames, 1.0);
      const easeProgress = 1 - Math.pow(1 - progress, 3); // Cubic Ease-Out

      const currentScale = 1 + (targetScale - 1) * easeProgress;
      const currentTx = targetTranslateX * easeProgress;
      const currentTy = targetTranslateY * easeProgress;

      magImage.style.transform = `scale(${currentScale}) translate(${currentTx}%, ${currentTy}%)`;

      // Dynamic Shadow (increases as we zoom in)
      const shadowBlur = 50 + (currentScale * 20);
      magContainer.style.boxShadow = `0px 20px ${shadowBlur}px rgba(0,0,0,0.8)`;

      // Fade In / Out
      if (progress < 0.05) {
          fadeOverlay.style.opacity = 1 - (progress / 0.05);
      } else if (progress > 0.95) {
          fadeOverlay.style.opacity = (progress - 0.95) / 0.05;
      } else {
          fadeOverlay.style.opacity = 0;
      }

      // Progress bar
      progressBar.style.width = `${progress * 100}%`;

      for (let i = 0; i < words.length; i++) {
        const w = words[i];
        w.element.classList.remove('active', 'past');

        if (currentTime >= w.start && currentTime <= w.end) {
            w.element.classList.add('active');

            // Calculate pop/bounce math based on time since word started
            const t = currentTime - w.start;
            // Spring math: scale = 1.15 + 0.2 * sin(15*t) * e^(-10*t)
            const popScale = 1.15 + (0.2 * Math.sin(15 * t) * Math.exp(-10 * t));
            w.element.style.transform = `scale(${popScale})`;
        } else if (currentTime > w.end) {
            w.element.classList.add('past');
            w.element.style.transform = `scale(1.0)`;
        } else {
            w.element.style.transform = `scale(0.95)`;
        }
      }
    };
  </script>
</body>
</html>